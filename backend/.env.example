# Telegram auth
# Use either BOT_TOKEN or TELEGRAM_BOT_TOKEN.
BOT_TOKEN=
TELEGRAM_BOT_TOKEN=
TELEGRAM_AUTH_MAX_AGE_SECONDS=86400

# Local development
ALLOW_DEV_AUTH=true

# Admin panel
ENABLE_ADMIN=false
ADMIN_SECRET=

# Frontend / CORS
FRONTEND_URL=http://localhost:5173
FRONTEND_URLS=
CORS_ALLOW_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
CORS_ALLOW_ORIGIN_REGEX=

# Drone game limits
DRONE_SESSION_TTL_MINUTES=15
MAX_DRONE_COINS_PER_RUN=50
MAX_DRONE_SCORE_PER_SECOND=0.75
DRONE_SCORE_GRACE=10
